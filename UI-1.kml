      <BalloonStyle>
        <text><![CDATA[<html><head><style>
    body {
      width: 496px;
      margin: 8px;
    }
    .feature-media-container.slide {
      left: 0;
      top: 0;
      position: absolute;
    }
    .feature-media-container.card,
    .feature-media-container.simple {
      overflow-x: auto;
      margin-right: 8px;
    }
    .feature-media {
      white-space: nowrap;
      display: inline;
    }
    .feature-media img {
      height: 280px;
    }
    .feature-text-container {
      margin-top: 8px;
    }
    .feature-text-container.slide {
      left: 0;
      top: 0;
      position: absolute;
      padding: 8px;
      margin: 0;
      text-shadow: 1px 1px rgb(10, 10, 10);
      color: white;
    }
    .feature-text-section {
      margin-top: 8px;
    }
    .feature-title {
      font-size: 22px;
    }
    .feature-description {
      font-size: 13px;
    }
    </style></head><div class="feature-text-container simple"><div class="feature-title feature-text-section">$[name]</div><div class="feature-description feature-text-section">$[description]</div></div></html>]]></text>
        <displayMode>default</displayMode>
      </BalloonStyle>
    </Style>
