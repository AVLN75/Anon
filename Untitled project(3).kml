        <text><![CDATA[<div>Addresses</div>
import csv
from arcgis.gis import GIS
from arcgis.geocoding import geocode as arcgis_geocode
from arcgis.features import FeatureLayerCollection, FeatureSet
from arcgis.mapping import WebMap

# --- Connect to ArcGIS Online ---
gis = GIS(...)

# --- Load Network Locations from CSV ---
network_locations = {}
with open('network_locations.csv', 'r') as csvfile:
    reader = csv.DictReader(csvfile)
    for row in reader:
        network_locations[row['DeviceID']] = row['Address']

network_features = []
# ... (Define network_fields) ...

for device_id, address in network_locations.items():
    try:
        geocode_result = arcgis_geocode(address, search_extent="Harlingen, TX")[0]
        if geocode_result:
            coordinates = {'x': geocode_result['location']['x'], 'y': geocode_result['location']['y']}
            network_features.append({'geometry': coordinates, 'attributes': {'DeviceID': device_id, 'Address': address}})
    except Exception as e:
        print(f"Error geocoding {device_id}: {e}")

# --- Create Network Layer ---
network_layer = create_feature_layer(gis, "Network Devices", "esriGeometryPoint", network_fields, network_features)

# --- Process Photos and Create Web Map (as before) ---
# ...




# ...
network_data_items = [{"name": "Router at 123 Main St"}, {"location": "lon:-97.6, lat:26.2"}]

for item in network_data_items:
    if "at" in item.get("name", ""):
        address = item["name"].split("at ")[-1]
        # Geocode the address
    elif "lon" in item.get("location", "") and "lat" in item.get("location", ""):
        # Extract coordinates
        lon_str, lat_str = item["location"].split(",")
        lon = float(lon_str.split(":")[-1])
        lat = float(lat_str.split(":")[-1])
